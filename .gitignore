# ── Python ───────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/

# ── 虚拟环境 ─────────────────────────────
venv/
.venv/
env/

# ── 测试缓存 ─────────────────────────────
.pytest_cache/
.coverage
htmlcov/


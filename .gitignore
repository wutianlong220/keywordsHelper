~$*.docx        # Word 锁文件

# ── Claude Code 本地配置（个人，不入 git） ──
.claude/

# ── 隐私：inputs/ 研究关键词（保留目录） ──
inputs/*
!inputs/.gitkeep

# ── 隐私：outputs/ Excel 结果 + 中间 JSON（保留目录） ──
outputs/*
!outputs/.gitkeep